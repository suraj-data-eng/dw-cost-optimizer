{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "https://dw-cost-optimizer-backend.herokuapp.com/api/$1"
    },
    {
      "src": "^/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
