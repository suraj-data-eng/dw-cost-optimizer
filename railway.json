{
  "services": {
    "backend": {
      "build": {
        "builder": "heroku.buildpacks",
        "buildpacks": [
          "heroku/python"
        ]
      },
      "startCommand": "cd backend && uvicorn main:app --host 0.0.0.0 --port $PORT",
      "envPath": ".env.railway"
    },
    "frontend": {
      "build": {
        "builder": "heroku.buildpacks",
        "buildpacks": [
          "heroku/nodejs"
        ]
      },
      "startCommand": "cd frontend && npm run build && npx serve -s build -l $PORT",
      "envPath": ".env.railway"
    }
  }
}
